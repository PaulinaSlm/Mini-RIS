                        ms+=1
                    
    print(f"""RAPORT Z DNIA {dzien_str}
Do Zakladu zglosilo sie {fs} kobiety i {ms} mezczyzn. 
Wykonano: {tk} badan TK, {rtg} badan RTG, {mri} badan MRI i {usg} badan USG.
""")   

def raport(): 
    fs = 0
    ms = 0
    tk = 0
    rtg = 0
    mri = 0
    usg = 0

    for pacjent in baza:
        if pacjent.plec=="f":
            fs+=1
        elif pacjent.plec=="m":
            ms+=1
        for badanie in pacjent.badanie:
            if hasattr(badanie, 'nazwa_skr'):
                match badanie.nazwa_skr:
                    case "tk":
                        tk+=1
                    case "rtg":
                        rtg+=1
                    case "mri":
                        mri+=1
                    case "usg":
                        usg+=1
        
    print(f"""RAPORT OGÓLNY
Do Zakladu zglosilo sie {fs} kobiety i {ms} mezczyzn. 
Wykonano: {tk} badan TK, {rtg} badan RTG, {mri} badan MRI i {usg} badan USG.
""")

def zapisz_baze(): 
    if not baza: 
        print("Baza jest pusta. Pomijam zapis.")
        return
    lista = [] 
    for pacjent in baza:
        if pacjent is None: 
            continue 
        for bad in pacjent.badanie: 
            dane = {"id":pacjent.id, 
                    "imie":pacjent.imie, 
                    "nazwisko":pacjent.nazwisko, 
                    "plec":pacjent.plec, 
                    "typ_badania":bad.nazwa_skr, 
                    "lokalizacja":bad.lokalizacja,
                    "data":bad.data.strftime("%d-%m-%Y") if isinstance(bad.data,datetime) else bad.data,
                    "lekarz_kierujacy":bad.lekarz_kierujacy}
            match bad.nazwa_skr:
                case "tk":
                    dane["dawka"]=bad.dawka
                    dane["kontrast"]=bad.kontrast
                    dane["tryb"]=bad.tryb
                case "rtg":
                    dane["dawka"]=bad.dawka
                    dane["pozycja"]=bad.pozycja
                    dane["projekcja"]=bad.projekcja
                case "mri":
                    dane["pole"]=bad.pole
                case "usg":
                    dane["glowica"]=bad.glowica
                    dane["doppler"]=bad.doppler
            lista.append(dane) 
    df = pd.DataFrame(lista) 
    df.to_csv("/Users/paulinaslomczynska/Documents/python_nauka/pacjenci/baza_szpitala.csv",index=False) 
    print("Zapisano dane do pliku.")


