def wczyt_baze(): 
    global idn
    if not os.path.exists("/Users/paulinaslomczynska/Documents/python_nauka/pacjenci/baza_szpitala.csv"): 
        print("Nie znaleziono pliku. Start z pusta baza.")
        return
    df = pd.read_csv("/Users/paulinaslomczynska/Documents/python_nauka/pacjenci/baza_szpitala.csv")
    for indeks,wiersz in df.iterrows(): 
        typ = wiersz["typ_badania"] 
        lokalizacja = wiersz["lokalizacja"]
        data = wiersz["data"]
        lekarz_kierujacy = wiersz["lekarz_kierujacy"]
        match typ: 
            case "tk":
                obj_badanie = TK()
                obj_badanie.dawka = float(wiersz["dawka"])
                obj_badanie.kontrast = wiersz["kontrast"]
                obj_badanie.tryb = wiersz["tryb"]
            case "rtg":
                obj_badanie = RTG()
                obj_badanie.dawka = float(wiersz["dawka"])
                obj_badanie.pozycja = wiersz["pozycja"]
                obj_badanie.projekcja = wiersz["projekcja"]
            case "mri":
                obj_badanie = MRI()
                obj_badanie.pole = float(wiersz["pole"])
            case "usg":
                obj_badanie = USG()
                obj_badanie.glowica = wiersz["glowica"]
                obj_badanie.doppler = wiersz["doppler"]
            case _:
                obj_badanie = Badania()
        
        obj_badanie.lokalizacja = lokalizacja
        obj_badanie.lekarz_kierujacy = lekarz_kierujacy
        try:
            obj_badanie.data = datetime.strptime(data,"%d-%m-%Y")
        except ValueError:
            obj_badanie.data = data
        
        id_pacjenta = int(wiersz["id"]) 
        w_bazie = None 
        for pacjent in baza: 
            if pacjent.id==id_pacjenta:
                w_bazie = pacjent
                break
        if w_bazie is not None: 
            w_bazie.badanie.append(obj_badanie)
        else: 
            if id_pacjenta >=idn:
                idn = id_pacjenta+1
            nowy = Pacjenci(id=id_pacjenta,imie=wiersz["imie"],nazwisko=wiersz["nazwisko"],plec=wiersz["plec"])
            nowy.badanie.append(obj_badanie)
            baza.append(nowy) 
    print(f"Pomyślnie załadowano baze. Wczytano {len(baza)} pacjentów.")
    return baza

def czy_w_bazie_jest_pacjent(name, surname): 
    for pac in baza:
        if pac.imie == name and pac.nazwisko == surname:
            return True, pac
    return False, None

def nowe_bad_dla_ist_pacjenta(name,surname): 
    czy, pac = czy_w_bazie_jest_pacjent(name,surname)
    if czy==True:
        bad = tworzenie_obiektu_badania()
        pac.badanie.append(bad)
    else:
        print("Pacjent nie istnieje w bazie.")
    return

def tworzenie_obiektu_badania(): 
    while True:
        nazwa = input("Podaj nazwę badania (TK,RTG,MRI,USG): ")
        nazwa = nazwa.lower()
        if nazwa!="tk" and nazwa!="rtg" and nazwa!="mri" and nazwa!="usg":
            kont = input("Wpisano nietypową nazwę badania. Czy chcesz ją poprawić? (tak/nie) ")
            if kont=="tak":
                continue
        
        match nazwa:
            case "tk":
                obj = TK()
                obj.nazwa_skr = nazwa
                obj.wpisz_lokalizacje()
                obj.wpisz_date()
                obj.wpisz_lekarza()
                obj.wpisz_dawke()
                obj.wpisz_kontrast()
                obj.wpisz_tryb()
            case "rtg":
                obj = RTG()
                obj.nazwa_skr = nazwa
                obj.wpisz_lokalizacje()
                obj.wpisz_date()
                obj.wpisz_lekarza()
                obj.wpisz_dawke()
                obj.wpisz_pozycje()
                obj.wpisz_projekcje()
            case "mri":
                obj = MRI()
                obj.nazwa_skr = nazwa
                obj.wpisz_lokalizacje()
                obj.wpisz_date()
                obj.wpisz_lekarza()
                obj.wpisz_pole()
            case "usg":
                obj = USG()
                obj.nazwa_skr = nazwa
                obj.wpisz_lokalizacje()
                obj.wpisz_date()
                obj.wpisz_lekarza()
                obj.wpisz_glowice()
                obj.czy_dopp()
            case _:
                obj = Badania()
                obj.nazwa_skr = nazwa
                obj.wpisz_lokalizacje()
                obj.wpisz_date()
                obj.wpisz_lekarza()
        return obj
            
def wprowadzenie_1pacjenta(): 
    imie = input("\nWprowadz imie pacjenta: ")
    imie = imie.lower()
    nazwisko = input("Wprowadz nazwisko pacjenta: ")
    nazwisko = nazwisko.lower()
    czy,pac = czy_w_bazie_jest_pacjent(imie,nazwisko)

    if czy==True: 
        print("Pacjent jest juz w bazie. Przekierowuje do dodania badania dla istniejacego pacjenta.")
        nowe_bad_dla_ist_pacjenta(imie,nazwisko)
        return None
    
    while True:
        plec = input("Wprowadz plec pacjenta (f/m/inna): ")
        plec = plec.lower()
        if plec!="f" and plec!="m" and plec!="inna":
            print("Nieznana płeć.")
        else:
            break

    bad = tworzenie_obiektu_badania()

    pac = Pacjenci(idn,imie,nazwisko,plec)
    pac.badanie.append(bad)
    return pac

def wprowadzenie_xpacjentow(): 
    global idn
    while True:
        try:
            x = int(input("Ilu pacjentow chcesz wprowadzic do bazy? "))
            if x<0:
                print("Nalezy wprowadzic wartosc dodatnia.")
                continue
            elif x==0:
                print("Nie chcesz wprowadzić zadnego pacjenta. Wprowadzanie zatrzymano.")
                return None
            for i in range(1,x+1):
                pac = wprowadzenie_1pacjenta()
                baza.append(pac)
            idn += 1
            return baza, idn
        except ValueError:
            print("Nalezy wprowadzic wartosc liczbową.")  

def usuniecie_pacj(): 
    pacjent = None
    while True:
        try:
            x = int(input("Wprowadz id badania do usuniecia: "))
            if x>idn or x<=0:
                print("Wybrane ID nie istnieje.")
                continue
            break
        except ValueError:
            print("Nalezy wprowadzic wartość liczbową.")

    for p in baza:
        if x==p.id:
            pacjent = p
            break   
    if pacjent is None:
        print("Nie znaleziono pacjenta o podanym ID.")
        return         

    while True:
        potw = input(f"Potwierdz wybranie pacjenta: {pacjent.imie.capitalize()} {pacjent.nazwisko.capitalize()} (tak / nie): ")
        if potw=="tak":
            baza.remove(pacjent)
            print("Wybrany pacjent zostal usuniety z bazy.")
            break
        elif potw=="nie":
            print("Zatrzymano usuwanie pacjenta.")
            break
        else:
            print("Nieznana komenda.")
    return baza

def usuwanie_badania():
    while True:
        try:
            id_pacjenta = int(input("Wprowadz ID pacjenta: "))
            if id_pacjenta>idn or id_pacjenta<=0:
                print("Wprowadzone ID nie istnieje.")
                continue
            break
        except ValueError:
            print("Nalezy wprowadzić wartość liczbową.")
    for pacjent in baza:
        if pacjent.id==id_pacjenta:
            print(f"Badania pacjenta {pacjent.imie} {pacjent.nazwisko}:")
            x=1
            for badanie in pacjent.badanie:
                print(f"{x}. {badanie.nazwa_skr.upper()} {badanie.lokalizacja}")
                x+=1
            while True:
                try:
                    wybor = int(input("Wprowadz numer badanie, które chcesz usunąć: "))
                    if wybor>x or wybor<=0:
                        print("Nie ma takiego badania")
                        continue
                    del pacjent.badanie[wybor-1]
                    print("Pomyślnie usunięto badanie z bazy.")
                    if pacjent.badanie==[]:
                        print(f"To było ostatnie badanie pacjenta {pacjent.imie} {pacjent.nazwisko}. Pacjent zostanie usunięty z bazy.")
                        baza.remove(pacjent)
                    break
                except ValueError:
                    print("Nalezy wprowadzic wartość liczbową.")
            break
        else:
            continue

