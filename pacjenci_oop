class Badania:
    def __init__(self):
        self.lokalizacja = ""
        self.nazwa_skr = ""
        self.data = ""
        self.lekarz_kierujacy = ""

    def wpisz_lokalizacje(self):
        self.lokalizacja = input("Podaj obszar badany: ")
        self.lokalizacja = self.lokalizacja.lower()
        return self.lokalizacja
    
    def wpisz_date(self):
        while True:
            try:
                self.data = input("Podaj datę wykonania badania w formacie DD-MM-RRRR: ")
                self.data = datetime.strptime(self.data,"%d-%m-%Y")
                dzis = datetime.now()
                if self.data>dzis:
                    print("Wpisano datę z przyszłości.")
                else:
                    return self.data
            except ValueError:
                print("Wprowadzono nieprawidłowy format daty.")
    
    def wpisz_lekarza(self):
        self.lekarz_kierujacy = input("Podaj lekarza kierującego na badania: ")
        self.lekarz_kierujacy = self.lekarz_kierujacy.lower()
        return self.lekarz_kierujacy

class TK(Badania):
    def __init__(self):
        super().__init__()
        self.nazwa_skr = "tk"
        self.dawka = 0.0
        self.kontrast = ""
        self.tryb = "" # SECT / DECT
    
    def wpisz_dawke(self):
        while True:
            try:
                self.dawka = float(input("Podaj dawke promieniowania, jaka otrzymal pacjent podczas badania: "))
                return self.dawka
            except ValueError:
                print("Nalezy wprowadzić wartość liczbową.")
    
    def wpisz_kontrast(self):
        while True:
            self.kontrast = input("Czy podczas badania podawany był środek kontrastowy? (wpisz tak lub nie) ")
            self.kontrast = self.kontrast.lower()
            if self.kontrast=="tak" or self.kontrast=="nie":
                return self.kontrast
            else:
                print('Nalezy wpisać "tak" lub "nie".')
    
    def wpisz_tryb(self):
        while True:
            self.tryb = input("Podaj tryb badania (SECT / DECT): ")
            self.tryb = self.tryb.lower()
            if self.tryb=="sect" or self.tryb=="dect":
                return self.tryb
            else:
                print('Nalezy wpisac tryb "SECT" lub "DECT".')
    
    def wypisz(self):
        print(f"""
Badanie TK {self.lokalizacja}
Data wykonania: {self.data}
Lekarz kierujący: {self.lekarz_kierujacy.capitalize()}
Dawka promieniowania: {self.dawka}
Środek kontrastowy: {self.kontrast}
Tryb: {self.tryb.upper()}""")
    
